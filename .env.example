# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Модель по умолчанию для большинства агентов
WORLDSIM_MODEL=claude-sonnet-4-6

# Модель для "тяжёлых" агентов: world-builder, canon-keeper
# По умолчанию — та же, что WORLDSIM_MODEL. Можно выставить claude-opus-4-7
# для более качественной генерации мира.
WORLDSIM_MODEL_HEAVY=claude-sonnet-4-6

# Папка, куда orchestrator пишет сейвы миров
WORLDSIM_SAVES_DIR=saves

# Язык игры (ru / en). На MVP — только ru.
WORLDSIM_LANG=ru

# Режим отладки: 1 — печатать сырые ответы LLM, 0 — нет
WORLDSIM_DEBUG=0
